{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/ids",
      "dest": "/api/ids.js"
    },
    {
      "src": "/secret-dunder-admin/download",
      "dest": "/api/secret-dunder-admin-download.js"
    },
    {
      "src": "/secret-dunder-admin",
      "dest": "/api/secret-dunder-admin.js"
    },
    {
      "src": "/styles.css",
      "dest": "/public/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/public/app.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
